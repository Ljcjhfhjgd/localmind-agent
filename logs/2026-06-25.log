# 假设 scores 是一个包含50个学生成绩的列表
scores = [85, 92, 76, ...] # 这里需要填充实际的成绩数据

average_score = np.mean(scores)
standard_deviation = np.std(scores)

print(f"平均成绩: {average_score}")
print(f"标准差: {standard_deviation}")
